<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Signing in…</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="auth-wrap">
  <div class="auth-card text-center">
    <p>✅ Signing you in, please wait…</p>
  </div>
</div>
<script>
  // Store JWT in localStorage (no cookies used – per project requirement)
  const token = "<%= token %>";
  localStorage.setItem('jwt_token', token);
  localStorage.setItem('username', "<%= username %>");
  localStorage.setItem('role', "<%= role %>");
  // Redirect to dashboard passing token in URL query
  window.location.href = "/dashboard?token=" + encodeURIComponent(token);
</script>
</body>
</html>
