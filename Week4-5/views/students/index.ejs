<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Students – BIT3208</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="layout">
  <%- include('../partials/sidebar', { token, activePage: 'students' }) %>
  <div class="main">
    <%- include('../partials/topbar', { title: 'Students', user }) %>
    <div class="content">

      <% if (msg) { %>
        <div class="alert alert-success" style="margin-bottom:1rem;"><%= msg %></div>
      <% } %>

      <div class="card">
        <div class="card-header">
          <h3>All Students (<%= students.length %>)</h3>
          <a href="/students/add?token=<%= token %>" class="btn btn-primary">➕ Add Student</a>
        </div>

        <% if (students.length === 0) { %>
          <div style="padding:2rem; text-align:center; color:#64748b;">
            No students found. <a href="/students/add?token=<%= token %>" class="link">Add the first one.</a>
          </div>
        <% } else { %>
        <table>
          <thead>
            <tr>
              <th>#</th>
              <th>Full Name</th>
              <th>Admission No.</th>
              <th>Course</th>
              <th>Email</th>
              <th>Phone</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% students.forEach((s, i) => { %>
            <tr>
              <td><%= i + 1 %></td>
              <td><strong><%= s.full_name %></strong></td>
              <td><span class="badge badge-blue"><%= s.admission_no %></span></td>
              <td><%= s.course || '—' %></td>
              <td><%= s.email || '—' %></td>
              <td><%= s.phone || '—' %></td>
              <td style="display:flex;gap:.4rem;">
                <a href="/students/edit/<%= s.id %>?token=<%= token %>" class="btn btn-warning">✏️ Edit</a>
                <a href="/students/delete/<%= s.id %>?token=<%= token %>"
                   class="btn btn-danger"
                   onclick="return confirm('Delete <%= s.full_name %>?')">🗑️ Delete</a>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } %>
      </div>

    </div>
  </div>
</div>
</body>
</html>
