<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> – BIT3208</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="layout">
  <%- include('../partials/sidebar', { token, activePage: 'add' }) %>
  <div class="main">
    <%- include('../partials/topbar', { title, user }) %>
    <div class="content">

      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <div class="form-card">
        <form method="POST" action="<%= action %>" onsubmit="return validateStudentForm()">
          <div class="form-grid">
            <div class="form-group">
              <label>Full Name *</label>
              <input type="text" name="full_name" value="<%= student ? student.full_name : '' %>" placeholder="e.g. Alice Wanjiku" required>
            </div>
            <div class="form-group">
              <label>Admission Number *</label>
              <input type="text" name="admission_no" value="<%= student ? student.admission_no : '' %>" placeholder="e.g. BIT/001/2024" required>
            </div>
            <div class="form-group">
              <label>Course</label>
              <input type="text" name="course" value="<%= student ? student.course : '' %>" placeholder="e.g. BIT">
            </div>
            <div class="form-group">
              <label>Phone</label>
              <input type="text" name="phone" value="<%= student ? student.phone : '' %>" placeholder="0712 000 000">
            </div>
          </div>
          <div class="form-group">
            <label>Email</label>
            <input type="email" name="email" value="<%= student ? student.email : '' %>" placeholder="student@email.com">
          </div>

          <div style="display:flex; gap:.75rem; margin-top:.5rem;">
            <button type="submit" class="btn btn-primary">💾 Save Student</button>
            <a href="/students?token=<%= token %>" class="btn btn-outline">Cancel</a>
          </div>
        </form>
      </div>

    </div>
  </div>
</div>
<script>
  function validateStudentForm() {
    const name = document.querySelector('[name=full_name]').value.trim();
    const adm  = document.querySelector('[name=admission_no]').value.trim();
    if (!name) { alert('Full name is required.'); return false; }
    if (!adm)  { alert('Admission number is required.'); return false; }
    return true;
  }
</script>
</body>
</html>
