<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register – BIT3208</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="auth-wrap">
  <div class="auth-card">
    <div class="auth-logo">🎓 BIT3208</div>
    <h1>Create Account</h1>
    <p class="sub">Register to access the student system</p>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success"><%= success %></div>
    <% } %>

    <form method="POST" action="/register" onsubmit="return validateForm()">
      <div class="form-group">
        <label>Username</label>
        <input type="text" name="username" placeholder="Choose a username" required>
      </div>
      <div class="form-group">
        <label>Email</label>
        <input type="email" name="email" placeholder="your@email.com" required>
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" id="pw" name="password" placeholder="Min 6 characters" required>
        <div id="pwStrength" style="height:4px;border-radius:2px;margin-top:6px;background:#e2e8f0;transition:background .3s;"></div>
      </div>
      <div class="form-group">
        <label>Confirm Password</label>
        <input type="password" id="pw2" name="confirm_password" placeholder="Repeat password" required>
        <span id="matchMsg" style="font-size:.75rem;"></span>
      </div>
      <button type="submit" class="btn btn-primary btn-full">Create Account</button>
    </form>

    <p class="text-center mt-2">
      Already have an account? <a href="/login" class="link">Sign in</a>
    </p>
  </div>
</div>

<script>
  // Password strength checker (Week 4 JS requirement)
  document.getElementById('pw').addEventListener('input', function() {
    const v = this.value, bar = document.getElementById('pwStrength');
    if (v.length === 0)      { bar.style.background = '#e2e8f0'; bar.style.width = '0%'; return; }
    const strong = v.length >= 8 && /[A-Z]/.test(v) && /[0-9]/.test(v) && /[^a-zA-Z0-9]/.test(v);
    const medium = v.length >= 6;
    bar.style.width = strong ? '100%' : medium ? '55%' : '25%';
    bar.style.background = strong ? '#16a34a' : medium ? '#d97706' : '#dc2626';
  });
  // Password match checker
  document.getElementById('pw2').addEventListener('input', function() {
    const msg = document.getElementById('matchMsg');
    if (this.value === document.getElementById('pw').value) {
      msg.textContent = '✓ Passwords match'; msg.style.color = '#16a34a';
    } else {
      msg.textContent = '✗ Passwords do not match'; msg.style.color = '#dc2626';
    }
  });
  function validateForm() {
    if (document.getElementById('pw').value !== document.getElementById('pw2').value) {
      alert('Passwords do not match!'); return false;
    }
    return true;
  }
</script>
</body>
</html>
