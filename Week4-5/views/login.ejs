<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login – BIT3208</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="auth-wrap">
  <div class="auth-card">
    <div class="auth-logo">🎓 BIT3208</div>
    <h1>Welcome back</h1>
    <p class="sub">Sign in to continue to your dashboard</p>

    <% if (msg) { %>
      <div class="alert alert-info"><%= msg %></div>
    <% } %>
    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form id="loginForm" method="POST" action="/login">
      <div class="form-group">
        <label for="username">Username</label>
        <input type="text" id="username" name="username" placeholder="Enter username" required>
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" placeholder="Enter password" required>
      </div>
      <button type="submit" class="btn btn-primary btn-full">Sign In</button>
    </form>

    <p class="text-center mt-2">
      Don't have an account? <a href="/register" class="link">Register here</a>
    </p>
    <p class="text-center mt-1" style="font-size:.75rem; color: #94a3b8;">
      Default: admin / Admin@1234
    </p>
  </div>
</div>
</body>
</html>
